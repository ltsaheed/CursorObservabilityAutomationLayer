{
  "name": "@instrument/orchestrator",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "instrument": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && node scripts/copyPrompts.mjs",
    "start": "node dist/index.js",
    "test": "tsc -p tsconfig.test.json && node --test dist/**/*.test.js",
    "typecheck": "tsc --noEmit"
  },
  "files": ["dist"],
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@cursor/sdk": "^1.0.23",
    "@instrument/mixpanel-client": "*",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "minimatch": "^10.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10"
  }
}
